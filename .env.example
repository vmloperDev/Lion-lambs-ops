# Firebase config (existing)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Gemini API key — used for:
#   1. "Paste & auto-fill with AI" on the Data Gathering form
#   2. Nexus AI in Team Chat (type @Nexus or tap the robot button)
# Get a key from https://aistudio.google.com/apikey
# NOTE: This key is bundled into the client-side app. Only use this for internal/
# trusted deployments — do not use on a public-facing site without a backend proxy.
VITE_GEMINI_API_KEY=

# Google Sheets sync — shared secret (optional but recommended)
# Set the SAME value here and as a Vercel env var named SHEETS_SYNC_SECRET
# (Vercel dashboard → Settings → Environment Variables, server-side only —
# do NOT prefix that one with VITE_). This stops /api/sheets-append from
# accepting requests from anyone who isn't running this app's build. Note
# this value IS bundled into the client JS (that's unavoidable for a
# frontend-only app), so it deters casual abuse of a stumbled-upon URL but
# is not real per-user authentication.
VITE_SHEETS_SYNC_SECRET=

# ── Server-side only env vars (set these in Vercel dashboard → Settings →
# Environment Variables, NEVER prefixed with VITE_ — these must stay off the
# client bundle) ──────────────────────────────────────────────────────────────
#
# Used by BOTH api/sheets-append.ts (instant sync) and api/cron-resync.ts
# (periodic full resync + self-heal):
#   GOOGLE_SERVICE_ACCOUNT_EMAIL   — from your Google Cloud service account
#   GOOGLE_PRIVATE_KEY             — from the same service account's JSON key
#   GOOGLE_SHEET_ID                — the ID from your spreadsheet's URL
#
# Used ONLY by api/cron-resync.ts (the periodic full resync — see CRON_SETUP.md
# for the complete step-by-step setup):
#   FIREBASE_PROJECT_ID     — same value as VITE_FIREBASE_PROJECT_ID above,
#                             just without the VITE_ prefix. Not a secret.
#   CRON_RESYNC_SECRET      — a secret string YOU make up (e.g. a long random
#                             password). Give this same value to whatever
#                             external scheduler calls /api/cron-resync so it
#                             can prove it's allowed to trigger a full resync.

